{
  "name": "@conduit/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:int": "dotenv -e ../../.env -- vitest run --config vitest.integration.config.ts",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "webhooks:generate": "dotenv -e ../../.env -- tsx scripts/webhook-generator.ts",
    "webhooks:stream": "dotenv -e ../../.env -- tsx scripts/webhook-generator.ts --stream"
  },
  "dependencies": {
    "@conduit/contracts": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.4.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^4.0.0",
    "rxjs": "^7.8.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@conduit/eslint-config": "workspace:*",
    "@conduit/tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "catalog:",
    "dotenv-cli": "^8.0.0",
    "eslint": "catalog:",
    "prisma": "^7.0.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
