# ── Database & queue (point at the docker-compose services) ──────────────────
DATABASE_URL="postgresql://conduit:conduit@localhost:5435/conduit"
REDIS_URL="redis://localhost:6380"

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT="3001"
WEB_ORIGIN="http://localhost:3000"

# ── Email delivery (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY="re_replace_me"
EMAIL_FROM="conduit@yourdomain.dev"

# ── Ingest HMAC ──────────────────────────────────────────────────────────────
# WEBHOOK_VERIFY=false bypasses signature verification for local/mock dev.
WEBHOOK_VERIFY="true"
# Per-source secrets (WEBHOOK_SECRET_<SOURCE-UPPERCASED>).
WEBHOOK_SECRET_STRIPE="whsec_replace_me"
WEBHOOK_SECRET_GITHUB="ghsec_replace_me"
WEBHOOK_SECRET_SLACK="slacksec_replace_me"

# ── Ingest rate limiting (per client IP) ─────────────────────────────────────
THROTTLE_TTL_MS="10000"
THROTTLE_LIMIT="100"

# ── Reliability backbone (all optional; sensible defaults shown) ──────────────
OUTBOX_DISPATCH_INTERVAL_MS="1000"
OUTBOX_BATCH_SIZE="100"
DELIVERY_MAX_ATTEMPTS="5"
DELIVERY_BACKOFF_MS="1000"
DELIVERY_DEDUP_WINDOW_MS="1000"
DELIVERY_FAIL_RATE="0"          # 0..1; raise to exercise retry/DLQ against the stub provider
RECONCILE_INTERVAL_MS="30000"

# ── Web (Next.js — NEXT_PUBLIC_* is exposed to the browser) ───────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_USE_MOCKS="false"
