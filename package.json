{
  "name": "conduit",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "db:generate": "pnpm --filter @conduit/api db:generate",
    "db:migrate": "pnpm --filter @conduit/api db:migrate",
    "db:seed": "pnpm --filter @conduit/api db:seed"
  },
  "devDependencies": {
    "prettier": "catalog:",
    "turbo": "^2.10.0",
    "typescript": "catalog:"
  }
}
